@startuml
interface services.IDatabaseService {
~ IAuthService getAuthService()
~ IUserService getUserService()
~ IMedicationService getMedicationService()
~ IMemoryGameService getGameService()
~ IStatsService getStatsService()
~ IForumService getForumService()
~ IImageService getImageService()
~ IForumCategoriesService getForumCategoriesService()
~ ITipOfTheDayService getTipOfTheDayService()
~ IEmergencyService getEmergencyService()
}

interface services.IDatabaseService$DatabaseCallback {
~ void onCompleted(T)
~ void onFailed(Exception)
}

interface services.IAdapterService {
~ ForumAdapter getForumAdapter()
~ ForumCategoryAdapter getForumCategoryAdapter()
~ MedicationListAdapter getMedicationListAdapter()
~ MemoryGameAdapter getMemoryGameAdapter()
~ MemoryGameLogAdapter getMemoryGameLogAdapter()
~ UsersTableAdapter getUsersTableAdapter()
~ MedicationImagesTableAdapter getMedicationImagesTableAdapter()
~ LeaderboardAdapter getLeaderboardAdapter()
~ MedicationUsageAdapter getMedicationUsageAdapter()
~ EmergencyContactsAdapter getEmergencyContactsAdapter()
~ GraphAdapter getGraphAdapter()
}

interface services.IAuthService {
~ void login(String,String,LoginCallback)
~ void register(String,String,String,String,String,RegisterCallback)
~ void addUser(String,String,String,String,String,AddUserCallback)
~ void updateUser(User,String,String,String,String,String,UpdateUserCallback)
~ String logout()
}

interface services.IAuthService$LoginCallback {
~ void onSuccess(User)
~ void onError(String)
}

interface services.IAuthService$RegisterCallback {
~ void onSuccess(User)
~ void onError(String)
}

interface services.IAuthService$AddUserCallback {
~ void onSuccess(User)
~ void onError(String)
}

interface services.IAuthService$UpdateUserCallback {
~ void onSuccess(User)
~ void onError(String)
}



services.IDatabaseService +.. services.IDatabaseService$DatabaseCallback
services.IAuthService +.. services.IAuthService$LoginCallback
services.IAuthService +.. services.IAuthService$RegisterCallback
services.IAuthService +.. services.IAuthService$AddUserCallback
services.IAuthService +.. services.IAuthService$UpdateUserCallback
@enduml
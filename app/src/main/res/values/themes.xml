<resources>

    <style name="Theme.SagivProject.Light" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:popupMenuStyle">@style/AppPopupMenuStyle</item>
        <item name="popupMenuStyle">@style/AppPopupMenuStyle</item>

        <item name="android:windowBackground">@color/background_color</item>
        <item name="colorPrimary">@color/background_color_nav</item>
        <item name="colorOnPrimary">@color/nav_text_color</item>
        <item name="android:textColor">@color/text_color</item>
        <item name="colorSecondary">@color/background_color_buttons</item>
        <item name="colorOnSecondary">@color/buttons_text_color</item>
        <item name="colorSurface">@color/background_color</item>
        <item name="colorOnSurface">@color/text_color</item>
        <item name="colorOutline">@color/text_color</item>
        <item name="textInputStyle">@style/AppTextInputLayoutStyle</item>
        <item name="editTextStyle">@style/AppTextInputEditTextStyle</item>
        <item name="colorError">@color/error</item>
        <item name="colorOnSurfaceVariant">@color/text_color</item>
        <item name="colorPrimaryContainer">@color/text_color</item>
        <item name="android:forceDarkAllowed">true</item>
    </style>

    <style name="FloatingDialogStyle" parent="Theme.Material3.DayNight.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowAnimationStyle">@style/DialogAnimation</item>
        <item name="android:windowMinWidthMajor">90%</item>
        <item name="android:windowMinWidthMinor">90%</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.6</item>

        <item name="colorPrimary">@color/background_color_nav</item>
        <item name="colorOnPrimary">@color/nav_text_color</item>
        <item name="colorSecondary">@color/background_color_buttons</item>
        <item name="colorOnSecondary">@color/buttons_text_color</item>
        <item name="colorSurface">@color/background_color</item>
        <item name="colorOnSurface">@color/text_color</item>
        <item name="colorOutline">@color/text_color</item>
    </style>

    <style name="DialogAnimation">
        <item name="android:windowEnterAnimation">@anim/dialog_enter</item>
        <item name="android:windowExitAnimation">@anim/dialog_exit</item>
    </style>

    <style name="AppPopupMenuStyle" parent="Widget.AppCompat.PopupMenu">
        <item name="android:popupBackground">@color/popup_background_color</item>
        <item name="android:textAppearance">@style/PopupMenuTextAppearance</item>
    </style>

    <style name="PopupMenuTextAppearance" parent="@android:style/TextAppearance">
        <item name="android:textColor">@color/text_color</item>
    </style>

    <style name="AppTextInputLayoutStyle" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/text_color</item>
        <item name="boxStrokeWidthFocused">1dp</item>
        <item name="hintTextColor">@color/text_color</item>
    </style>

    <style name="AppTextInputEditTextStyle" parent="Widget.Material3.TextInputEditText.OutlinedBox">
        <item name="android:textColor">@color/text_color</item>
        <item name="android:fontFamily">@font/text_hebrew</item>
    </style>

    <style name="TimePickerCustomTheme" parent="ThemeOverlay.Material3.MaterialTimePicker">
        <item name="colorSurface">@color/background_color</item>
        <item name="android:windowBackground">@color/background_color</item>
        <item name="android:colorBackground">@color/background_color</item>

        <item name="colorPrimary">@color/headline</item>
        <item name="colorOnPrimary">@color/buttons_text_color</item>
        <item name="colorAccent">@color/headline</item>

        <item name="colorSecondaryContainer">@color/background_color_buttons</item>
        <item name="colorOnSecondaryContainer">@color/text_color</item>

        <item name="colorOnSurface">@color/text_color</item>
        <item name="colorOnSurfaceVariant">@color/text_color</item>
        <item name="android:textColorPrimary">@color/text_color</item>
        <item name="android:textColorSecondary">@color/text_color</item>
        <item name="colorOutline">@color/headline</item>

        <item name="buttonBarPositiveButtonStyle">@style/TimePickerButtonStyle</item>
        <item name="buttonBarNegativeButtonStyle">@style/TimePickerButtonStyle</item>
    </style>

    <style name="TimePickerButtonStyle" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/headline</item>
        <item name="android:fontFamily">@font/text_hebrew</item>
        <item name="android:textSize">18sp</item>
    </style>

    <style name="Theme.SagivProject" parent="Theme.SagivProject.Light" />

    <style name="CircleImage" parent="">
        <item name="cornerSize">50%</item>
    </style>

</resources>
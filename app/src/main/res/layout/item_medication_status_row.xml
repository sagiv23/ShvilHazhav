<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    style="?android:attr/buttonBarStyle"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="4dp">

    <TextView
        android:id="@+id/txt_MedicationRow_ScheduledTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:fontFamily="@font/text_hebrew"
        android:textSize="18sp"
        android:textStyle="bold"
        tools:text="00:00" />

    <Button
        android:id="@+id/btn_MedicationRow_Taken"
        style="?android:attr/buttonBarButtonStyle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:fontFamily="@font/text_hebrew"
        android:text="@string/took"
        android:textColor="@color/headline"
        android:textSize="16sp" />

    <Button
        android:id="@+id/btn_MedicationRow_NotTaken"
        style="?android:attr/buttonBarButtonStyle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:fontFamily="@font/text_hebrew"
        android:text="@string/didnt_take"
        android:textColor="@color/error"
        android:textSize="16sp" />

    <Button
        android:id="@+id/btn_MedicationRow_Snoozed"
        style="?android:attr/buttonBarButtonStyle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:fontFamily="@font/text_hebrew"
        android:text="@string/will_take"
        android:textColor="@color/text_color"
        android:textSize="16sp" />
</LinearLayout>

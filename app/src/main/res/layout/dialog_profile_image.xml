<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/colorSurface"
    android:layoutDirection="rtl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:fontFamily="@font/headline_hebrew"
            android:gravity="center"
            android:text="@string/options"
            android:textColor="@color/headline"
            android:textSize="28sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_profileImageDialog_camera"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:fontFamily="@font/text_hebrew"
            android:text="@string/take_a_photo"
            android:textAllCaps="false"
            android:textSize="20sp"
            app:cornerRadius="30dp"
            app:icon="@drawable/ic_camera"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconSize="24dp"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_profileImageDialog_gallery"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:fontFamily="@font/text_hebrew"
            android:text="@string/choose_from_gallery"
            android:textAllCaps="false"
            android:textSize="20sp"
            app:cornerRadius="30dp"
            app:icon="@drawable/ic_search"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconSize="24dp"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_profileImageDialog_delete"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:fontFamily="@font/text_hebrew"
            android:text="@string/delete_img"
            android:textAllCaps="false"
            android:textColor="@color/error"
            android:textSize="20sp"
            android:visibility="gone"
            app:cornerRadius="30dp"
            app:icon="@drawable/ic_cancel"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconSize="24dp"
            app:strokeColor="@color/error"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_profileImageDialog_cancel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/text_hebrew"
            android:text="@string/cancel"
            android:textAllCaps="false"
            android:textSize="20sp"
            app:cornerRadius="30dp"
            app:strokeColor="?attr/colorOutline"
            app:strokeWidth="1dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>

<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    android:layoutDirection="rtl"
    app:cardCornerRadius="24dp"
    app:cardElevation="4dp"
    app:strokeColor="?attr/colorOutline"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="20dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/img_UserRow_userProfile"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:contentDescription="@string/profile_img"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_user"
            app:shapeAppearanceOverlay="@style/CircleImage"
            app:strokeColor="@color/headline"
            app:strokeWidth="2dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txt_UserRow_fullName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/headline_hebrew"
                android:textColor="@color/headline"
                android:textSize="24sp"
                android:textStyle="bold"
                tools:text="שם מלא" />

            <TextView
                android:id="@+id/txt_UserRow_email"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:alpha="0.8"
                android:fontFamily="@font/text_english"
                android:textSize="18sp"
                tools:text="email@example.com" />

            <TextView
                android:id="@+id/txt_UserRow_IsAdmin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/text_hebrew"
                android:textColor="@color/headline"
                android:textSize="18sp"
                tools:text="מנהל: לא" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btn_UserRow_DeleteUser"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/delete"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_delete" />

            <ImageButton
                android:id="@+id/btn_UserRow_MakeAdmin"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/make_admin"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_add_admin" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>

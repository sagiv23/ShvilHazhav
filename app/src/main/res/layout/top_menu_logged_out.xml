<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color_nav"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="50dp"
        android:layout_marginBottom="24dp"
        android:fontFamily="@font/headline_hebrew"
        android:gravity="center"
        android:text="@string/app_name"
        android:textColor="@color/nav_text_color"
        android:textSize="24sp"
        android:textStyle="bold" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_menu_main"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/text_hebrew"
        android:gravity="start|center_vertical"
        android:layoutDirection="ltr"
        android:text="@string/landing"
        android:textColor="@color/nav_text_color"
        android:textSize="18sp"
        app:icon="@drawable/ic_home"
        app:iconGravity="textStart"
        app:iconSize="24dp"
        app:iconTint="@color/nav_text_color" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_menu_login"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/text_hebrew"
        android:gravity="start|center_vertical"
        android:layoutDirection="ltr"
        android:text="@string/log_in"
        android:textColor="@color/nav_text_color"
        android:textSize="18sp"
        app:icon="@drawable/ic_login"
        app:iconGravity="textStart"
        app:iconSize="24dp"
        app:iconTint="@color/nav_text_color" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_menu_register"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/text_hebrew"
        android:gravity="start|center_vertical"
        android:layoutDirection="ltr"
        android:text="@string/register"
        android:textColor="@color/nav_text_color"
        android:textSize="18sp"
        app:icon="@drawable/ic_register"
        app:iconGravity="textStart"
        app:iconSize="24dp"
        app:iconTint="@color/nav_text_color" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_menu_contact"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/text_hebrew"
        android:gravity="start|center_vertical"
        android:layoutDirection="ltr"
        android:text="@string/contact"
        android:textColor="@color/nav_text_color"
        android:textSize="18sp"
        app:icon="@drawable/ic_contact_support"
        app:iconGravity="textStart"
        app:iconSize="24dp"
        app:iconTint="@color/nav_text_color" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="8dp"
        android:background="@color/headline" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_menu_settings"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/text_hebrew"
        android:gravity="start|center_vertical"
        android:layoutDirection="ltr"
        android:text="@string/settings"
        android:textColor="@color/nav_text_color"
        android:textSize="18sp"
        app:icon="@drawable/ic_settings"
        app:iconGravity="textStart"
        app:iconSize="24dp"
        app:iconTint="@color/nav_text_color" />

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/emergencyContactsPage"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layoutDirection="rtl"
    tools:context=".screens.EmergencyContactsFragment">

    <include
        layout="@layout/include_top_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintBottom_toTopOf="@id/bottom_actions"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/separatorLine">

        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/headline_hebrew"
            android:text="@string/emergency_contacts"
            android:textColor="@color/headline"
            android:textSize="35sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:gravity="center_horizontal"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_contact_dialog"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:fontFamily="@font/text_hebrew"
                android:text="@string/add"
                android:textAllCaps="false"
                android:textSize="20sp"
                app:cornerRadius="30dp"
                app:icon="@drawable/ic_add"
                app:iconGravity="textStart"
                app:iconPadding="12dp"
                app:iconSize="28dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_pick_contact"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:fontFamily="@font/text_hebrew"
                android:text="@string/choose_from_contacts"
                android:textAllCaps="false"
                android:textSize="20sp"
                app:cornerRadius="30dp"
                app:icon="@drawable/ic_search"
                app:iconGravity="textStart"
                app:iconPadding="12dp"
                app:iconSize="28dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/txt_no_contacts"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="32dp"
            android:fontFamily="@font/text_hebrew"
            android:text="@string/no_emergency_contacts"
            android:textSize="20sp"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_emergency_contacts"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_weight="1"
            android:clipToPadding="false" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottom_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?android:attr/windowBackground"
        android:elevation="8dp"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_send_emergency_sms"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="@color/error"
            android:fontFamily="@font/text_hebrew"
            android:text="@string/send_emergency_sms"
            android:textAllCaps="false"
            android:textSize="22sp"
            app:cornerRadius="30dp"
            app:icon="@drawable/ic_forum"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconSize="28dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_call_109"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:fontFamily="@font/text_hebrew"
            android:text="@string/call_emergency_109"
            android:textAllCaps="false"
            android:textSize="22sp"
            app:cornerRadius="30dp"
            app:icon="@drawable/ic_phone"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconSize="28dp" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>

<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    android:layoutDirection="rtl"
    app:cardCornerRadius="20dp"
    app:cardElevation="8dp"
    app:strokeColor="?attr/colorOutline"
    app:strokeWidth="1.5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        android:weightSum="10">

        <TextView
            android:id="@+id/tv_ItemUserRank_user_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="8"
            android:ellipsize="end"
            android:fontFamily="@font/headline_hebrew"
            android:gravity="start|center_vertical"
            android:layoutDirection="rtl"
            android:maxLines="1"
            android:textColor="@color/text_color"
            android:textSize="18sp"
            tools:text="שם פרטי + משפחה" />

        <TextView
            android:id="@+id/tv_ItemUserRank_wins"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:fontFamily="@font/text_hebrew"
            android:gravity="center"
            android:textColor="@color/headline"
            android:textSize="24sp"
            android:textStyle="bold"
            tools:text="5" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>

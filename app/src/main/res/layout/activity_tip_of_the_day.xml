<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layoutDirection="rtl"
    tools:context=".screens.TipOfTheDayActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/tipOfTheDayPage"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <include
            android:id="@+id/top_bar_include"
            layout="@layout/include_top_bar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.core.widget.NestedScrollView
            android:id="@+id/nsv_tip_of_the_day"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:fillViewport="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/top_bar_include">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:layoutAnimation="@anim/layout_pro_stagger"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:fontFamily="@font/headline_hebrew"
                    android:text="@string/daily_tip"
                    android:textColor="@color/headline"
                    android:textSize="40sp" />

                <TextView
                    android:id="@+id/tv_tip_of_the_day_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:fontFamily="@font/text_hebrew"
                    android:textSize="25sp"
                    tools:text="23/11/2008" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_daily_tip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="32dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp"
                    app:strokeColor="?attr/colorOutline"
                    app:strokeWidth="1.5dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <TextView
                            android:id="@+id/tv_tipOfTheDay_content"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/text_hebrew"
                            android:gravity="center"
                            android:textSize="22sp"
                            tools:text="כאן יוצג הטיפ היומי" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_tip_speak"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="16dp"
                            android:fontFamily="@font/text_hebrew"
                            android:text="@string/playback"
                            android:textAllCaps="false"
                            android:textSize="20sp"
                            app:cornerRadius="30dp"
                            app:icon="@drawable/ic_sound"
                            app:iconGravity="textStart"
                            app:iconPadding="12dp"
                            app:iconSize="28dp"
                            app:strokeWidth="1dp" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_inspiration"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="32dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp"
                    app:strokeColor="?attr/colorOutline"
                    app:strokeWidth="1.5dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginBottom="8dp"
                            android:fontFamily="@font/headline_hebrew"
                            android:text="@string/inspiration_corner"
                            android:textColor="@color/headline"
                            android:textSize="30sp" />

                        <TextView
                            android:id="@+id/tv_tipOfTheDay_inspiration_content"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:fontFamily="@font/text_hebrew"
                            android:gravity="center"
                            android:textSize="20sp"
                            tools:text="כאן יופיע משפט השראה, סיפור קצר או בדיחה" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_inspiration_speak"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="16dp"
                            android:fontFamily="@font/text_hebrew"
                            android:text="@string/playback"
                            android:textAllCaps="false"
                            android:textSize="20sp"
                            app:cornerRadius="30dp"
                            app:icon="@drawable/ic_sound"
                            app:iconGravity="textStart"
                            app:iconPadding="12dp"
                            app:iconSize="28dp"
                            app:strokeWidth="1dp" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/tab_layout_admin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone"
                    app:tabIndicatorFullWidth="false"
                    app:tabRippleColor="@null"
                    app:tabSelectedTextColor="@color/headline"
                    app:tabTextAppearance="@style/TextAppearance.MaterialComponents.Button"
                    app:tabTextColor="@color/text_color">

                    <com.google.android.material.tabs.TabItem
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/all_tips" />

                    <com.google.android.material.tabs.TabItem
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/inspiration_pool" />
                </com.google.android.material.tabs.TabLayout>

                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/tab_layout_months"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone"
                    app:tabIndicatorColor="@color/headline"
                    app:tabIndicatorFullWidth="false"
                    app:tabMode="scrollable"
                    app:tabRippleColor="@null"
                    app:tabSelectedTextColor="@color/headline"
                    app:tabTextAppearance="@style/TextAppearance.MaterialComponents.Button"
                    app:tabTextColor="@color/text_color" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_calendar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp"
                    app:strokeColor="?attr/colorOutline"
                    app:strokeWidth="1.5dp">

                    <CalendarView
                        android:id="@+id/cv_tip_calendar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="8dp" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_selected_tip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="32dp"
                    android:visibility="gone"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp"
                    app:strokeColor="@color/headline"
                    app:strokeWidth="2dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="24dp">

                        <ImageButton
                            android:id="@+id/btn_close_selected_tip"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="@string/exit"
                            android:src="@drawable/ic_x"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="@color/headline" />

                        <TextView
                            android:id="@+id/tv_selected_tip_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/headline_hebrew"
                            android:text="@string/selected_tip"
                            android:textColor="@color/headline"
                            android:textSize="28sp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/tv_selected_tip_date"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="@font/text_hebrew"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tv_selected_tip_title"
                            tools:text="20/05/2024" />

                        <TextView
                            android:id="@+id/tv_selected_tip_content"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:fontFamily="@font/text_hebrew"
                            android:gravity="center"
                            android:textSize="20sp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tv_selected_tip_date"
                            tools:text="תוכן הטיפ שנבחר מהיומן יוצג כאן." />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_selected_tip_speak"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:fontFamily="@font/text_hebrew"
                            android:text="@string/playback"
                            android:textAllCaps="false"
                            android:textSize="20sp"
                            app:cornerRadius="30dp"
                            app:icon="@drawable/ic_sound"
                            app:iconGravity="textStart"
                            app:iconPadding="12dp"
                            app:iconSize="28dp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tv_selected_tip_content"
                            app:strokeWidth="1dp" />

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_add_tip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:fontFamily="@font/text_hebrew"
                    android:text="@string/add_new_tip"
                    android:textAllCaps="false"
                    android:textSize="20sp"
                    android:visibility="gone"
                    app:cornerRadius="30dp"
                    app:icon="@drawable/ic_add"
                    app:iconGravity="textStart"
                    app:iconPadding="12dp"
                    app:iconSize="28dp"
                    app:strokeWidth="1dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_all_tips"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="32dp"
                    android:nestedScrollingEnabled="false"
                    android:visibility="gone"
                    tools:listitem="@layout/item_tip" />

                <TextView
                    android:id="@+id/tv_no_tips_error"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="32dp"
                    android:fontFamily="@font/text_hebrew"
                    android:text="@string/no_tips_to_show"
                    android:textSize="22sp"
                    android:visibility="gone" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/drawer_menu_container"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start" />

</androidx.drawerlayout.widget.DrawerLayout>
